{
  "compilerOptions": {
    "target": "ES2022", // Or your desired target JavaScript version
    "module": "CommonJS", // Or "ESNext" for ES Modules
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}